{
  "name": "agent-todo",
  "version": "0.0.0",
  "private": true,
  "description": "AI-powered task board with built-in agent support",
  "type": "module",
  "bin": {
    "agent-todo": "./bin/agent-todo.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "server/",
    "shared/"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:full": "concurrently -n \"server,vite\" -c \"blue,green\" \"node server/index.mjs\" \"vite dev --port 3000\"",
    "server": "node server/index.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "pnpm test:core",
    "test:core": "vitest run",
    "test:e2e": "node -e \"console.log('E2E tests are intentionally deferred during rapid iteration.')\"",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "biome:check": "biome check .",
    "format": "biome check . --write",
    "start": "node bin/agent-todo.mjs",
    "check:ci": "pnpm typecheck && pnpm biome:check && pnpm test:core"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.97",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "boneyard-js": "^1.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
