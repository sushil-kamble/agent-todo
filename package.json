{
  "name": "agentodo",
  "version": "0.1.0",
  "description": "Local-first kanban board for AI agent tasks. Turn coding prompts into structured tasks, run Claude Code or Codex against them, keep the transcripts.",
  "keywords": [
    "ai",
    "agent",
    "claude",
    "claude-code",
    "codex",
    "kanban",
    "todo",
    "task-board",
    "cli",
    "anthropic"
  ],
  "author": "Sushil Kamble",
  "license": "MIT",
  "homepage": "https://github.com/sushil-kamble/agent-todo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushil-kamble/agent-todo.git"
  },
  "bugs": {
    "url": "https://github.com/sushil-kamble/agent-todo/issues"
  },
  "type": "module",
  "bin": {
    "agentodo": "./bin/agentodo.mjs"
  },
  "files": [
    "bin",
    "packages/server/src",
    "packages/server/package.json",
    "packages/shared/src",
    "packages/shared/package.json",
    "packages/client/dist",
    "packages/client/package.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.97",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-router": "^1.168.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"blue,green\" \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "pnpm --filter @agent-todo/client dev",
    "dev:server": "pnpm --filter @agent-todo/server dev",
    "build": "pnpm --filter @agent-todo/shared build && pnpm --filter @agent-todo/client build",
    "preview": "pnpm --filter @agent-todo/client preview",
    "test": "pnpm --recursive --if-present run test",
    "test:e2e": "node -e \"console.log('E2E tests are intentionally deferred during rapid iteration.')\"",
    "typecheck": "pnpm --recursive --if-present run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "biome:check": "biome check .",
    "format": "biome check . --write",
    "start": "node bin/agentodo.mjs",
    "prepublishOnly": "pnpm run build",
    "check:ci": "pnpm typecheck && pnpm biome:check && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
